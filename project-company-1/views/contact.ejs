<%- include('partials/header') %>
  <section class="hero contact-hero animate-fade-up delay-1">
    <div>
      <small>JOIN ULTRAS</small>
      <h2>Komunitas Roblox untuk mencari teman</h2>
      <p>ULTRAS adalah server Roblox untuk pemain yang ingin bertemu teman baru, ikut acara, dan berkembang bersama.</p>
      <% if (typeof success !== 'undefined' && success) { %>
        <p class="success">Terima kasih, <%= (form || {}).name ? form.name : 'teman' %> — permintaan gabungmu sudah diterima.</p>
      <% } %>
    </div>

    <div class="contact-actions animate-fade-up delay-2">
      <a class="cta-button secondary" href="<%= discordInvite %>" target="_blank" rel="noopener">Join Discord<span class="action-note">Masuk ke komunitas Roblox</span></a>
    </div>
  </section>

  <section class="contact-grid animate-fade-up delay-3">
    <div class="contact-panel">
      <div class="contact-card">
        <h3>ULTRAS COMMUNITY</h3>
        <p>Temukan teman Roblox, masuk ke chat room aktif, dan kalau kamu suka main yang sama bisa langsung terhubung.</p>
        <div class="contact-meta">
          <div class="contact-meta-row"><strong>Discord</strong><span><%= discordInvite %></span></div>
          <div class="contact-meta-row"><strong>Fokus</strong><span>Persahabatan Roblox, acara, dan permainan komunitas</span></div>
        </div>
      </div>

      <div class="contact-card">
        <h3>Apa yang ULTRAS tawarkan</h3>
        <p>Bergabunglah dengan komunitas Roblox yang hidup, lengkap dengan acara, grup teman, dan channel khusus pemain.</p>
        <ul>
          <li>Mencari teman dan membentuk tim</li>
          <li>Malam acara Roblox dan pesta komunitas</li>
          <li>Channel untuk undangan game, klip, dan kreasi</li>
        </ul>
      </div>
    </div>

    <div class="contact-panel contact-form-panel card animate-fade-up delay-4">
      <form id="contactForm" method="post" action="/contact" class="contact-form">
        <div class="form-group">
          <label>Username Roblox</label>
          <input type="text" name="name" required value="<%= (form || {}).name ? form.name : '' %>">
        </div>
        <div class="form-group">
          <label>Email</label>
          <input id="emailField" type="email" name="email" required value="<%= (form || {}).email ? form.email : '' %>">
        </div>
        <div class="form-group">
          <label>Game Roblox favorit</label>
          <input type="text" name="favoriteGames" value="<%= (form || {}).favoriteGames ? form.favoriteGames : '' %>">
        </div>
        <div class="form-group">
          <label>Mengapa kamu ingin bergabung?</label>
          <textarea id="messageField" name="message" required><%= (form || {}).message ? form.message : '' %></textarea>
        </div>
        <div class="contact-form-footer">
          <button type="submit">Minta Undangan</button>
        </div>
      </form>
    </div>
  </section>

<%- include('partials/footer') %>
